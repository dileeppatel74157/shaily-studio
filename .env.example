# Environment Setup
NODE_ENV=development
PYTHON_ENV=development

# PostgreSQL Database
POSTGRES_USER=shaily_admin
POSTGRES_PASSWORD=shaily_secure_password_123
POSTGRES_DB=shaily_studio_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DB connection string for SQLAlchemy (using psycopg driver)
DATABASE_URL=postgresql+psycopg://shaily_admin:shaily_secure_password_123@localhost:5432/shaily_studio_dev

# Redis Queue & Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# FastAPI Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Next.js Frontend Configuration
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
